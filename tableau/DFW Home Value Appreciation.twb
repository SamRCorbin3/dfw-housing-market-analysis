      <aliases enabled='yes' />
      <column caption='Appreciation Percent' datatype='real' name='[Appreciation_Percent]' role='measure' type='quantitative' />
      <column caption='Appreciation Rank' datatype='integer' name='[Calculation_3803502254223360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Appreciation_Percent]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top Appreciating City' datatype='string' name='[Calculation_3803502254473217]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_3803502254223360] = 1 THEN&#13;&#10;    &quot;Highest&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='City_State' datatype='string' name='[Calculation_3803502254624770]' role='dimension' semantic-role='' type='nominal'>
        <calculation class='tableau' formula='[City] + &quot;, TX&quot;' />
      </column>
      <column caption='Average Appreciation' datatype='real' name='[Calculation_3803502254936067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Appreciation_Percent])' />
      </column>
      <column caption='Cities Above Average' datatype='integer' name='[Calculation_3803502255300612]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Appreciation_Percent] &gt; { FIXED : AVG([Appreciation_Percent]) }&#13;&#10;THEN [City]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Lowest Appreciation' datatype='real' name='[Calculation_3803502429327366]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Appreciation_Percent])' />
      </column>
      <column caption='Lowest Appreciating City' datatype='string' name='[Calculation_3803502445408264]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Appreciation_Percent] = { FIXED : MIN([Appreciation_Percent]) }&#13;&#10;THEN &quot;Lowest&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Top Appreciating County' datatype='string' name='[Calculation_3803502468681737]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Appreciation_Percent]) = WINDOW_MAX(AVG([Appreciation_Percent]))&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[County]' role='dimension' semantic-role='[County].[Name]' type='nominal' />
