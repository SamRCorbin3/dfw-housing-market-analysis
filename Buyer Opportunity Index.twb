      <column caption='Affordability Rank' datatype='integer' name='[Affordability_Rank]' role='measure' type='quantitative' />
      <column caption='Appreciation Percent' datatype='real' name='[Appreciation_Percent]' role='measure' type='quantitative' />
      <column caption='Appreciation Rank' datatype='integer' name='[Appreciation_Rank]' role='measure' type='quantitative' />
      <column caption='Buyer Opportunity Rank' datatype='integer' name='[Buyer_Opportunity_Rank]' role='measure' type='quantitative' />
      <column caption='Buyer Opportunity Score' datatype='integer' name='[Buyer_Opportunity_Score]' role='measure' type='quantitative' />
      <column caption='Highest Opportunity Score' datatype='integer' name='[Calculation_3547041851936769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Buyer_Opportunity_Score])' />
      </column>
      <column caption='Average Opportunity Score' datatype='real' name='[Calculation_3547041852067842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Buyer_Opportunity_Score])' />
      </column>
      <column caption='Lowest Opportunity Score' datatype='integer' name='[Calculation_3547041852239875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Buyer_Opportunity_Score])' />
      </column>
      <column caption='Top Opportunity City' datatype='string' name='[Calculation_3547041852338180]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Buyer_Opportunity_Score]&#13;&#10;=&#13;&#10;{ FIXED : MAX([Buyer_Opportunity_Score]) }&#13;&#10;&#13;&#10;THEN &quot;Top&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Cities Above Average Opportunity' datatype='integer' name='[Calculation_3547041852465157]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;&#13;&#10;IF [Buyer_Opportunity_Score]&#13;&#10;&gt;&#13;&#10;{ FIXED : AVG([Buyer_Opportunity_Score]) }&#13;&#10;&#13;&#10;THEN [City]&#13;&#10;&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Top Opportunity County' datatype='boolean' name='[Calculation_3547041858523142]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [County] : AVG([Buyer_Opportunity_Score]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [County] : AVG([Buyer_Opportunity_Score]) }&#13;&#10;)&#13;&#10;}' />
      </column>
      <column caption='IF Statement' datatype='string' name='[Calculation_3547041860505607]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [County] : AVG([Buyer_Opportunity_Score]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [County] : AVG([Buyer_Opportunity_Score]) }&#13;&#10;)&#13;&#10;}&#13;&#10;&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;&#13;&#10;END' />
      </column>
